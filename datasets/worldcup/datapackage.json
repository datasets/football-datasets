    {
      "name": "CC-BY-SA-4.0",
      "title": "Creative Commons Attribution-ShareAlike 4.0 International",
      "path": "https://creativecommons.org/licenses/by-sa/4.0/legalcode"
    }
  ],
  "sources": [
    {
      "title": "Fjelstul World Cup Database",
      "path": "https://github.com/jfjelstul/worldcup",
      "author": "Joshua C. Fjelstul, Ph.D.",
      "copyright": "© 2023 Joshua C. Fjelstul, Ph.D."
    }
  ],
